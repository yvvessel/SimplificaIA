# ====================================
# SimplificaIA Backend - Environment Variables
# ====================================
# IMPORTANTE: Nunca compartilhe este arquivo!
# Copie este arquivo para .env e preencha com seus valores
# 
# Este arquivo será ignorado pelo Git automaticamente
# ====================================

# API Keys
GEMINI_API_KEY=sua_chave_api_do_gemini_aqui

# Backend Configuration
HOST=0.0.0.0
PORT=8000
DEBUG=false

# Rate Limiting
RATE_LIMIT_USES_PER_DAY=5

# Cache Configuration
CACHE_TTL_DAYS=30
MAX_CACHED_ENTRIES=1000

# Database Paths (opcional, pode usar defaults)
# DATABASE_URL=sqlite:///./app.db
# CACHE_DB_PATH=./cache.db
# USAGE_DB_PATH=./usage.db

# CORS (se necessário)
# ALLOWED_ORIGINS=http://localhost:3000,http://192.168.1.100:8081
